# Yu-Gi-Oh! Master Duel Bot — LLM-based

# ── LLM Provider ──
# Pilih SALAH SATU. Hapus # di depan yang dipake.
# Google Gemini — gratis 1.500 req/hari (recommended untuk start)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter — satu key buat banyak model
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-xxx
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Groq — paling cepet delay <1s, gratis
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Bot Config ──
# Nama window Master Duel (untuk capture)
GAME_WINDOW=Yu-Gi-Oh! Master Duel
# Delay antar action (detik)
ACTION_DELAY=1.5
# Interval screenshot saat menunggu (detik)
POLL_INTERVAL=2.0
# Konfirmasi manual sebelum tiap move (true/false)
MANUAL_CONFIRM=false
